# ============================================================================
#  ~/voip-<name>/.env   —  per-persona voice-call profile
#  Copy to ~/voip-<name>/.env, chmod 600, fill in. NEVER commit a real one.
#  Placeholders: <name> persona id · USER your unix user · INFER_HOST gpu box ·
#  SERVER_IP public ip · <secret> = mint with scripts/gen-secrets.sh
#  (The VOXTRAL_* prefix is legacy naming — it drives Qwen3-TTS now.)
# ============================================================================

# ── Identity / Matrix ───────────────────────────────────────────────────────
MATRIX_HOMESERVER_URL=http://127.0.0.1:8008
MATRIX_USER_ID=@<name>:matrix.example.com
MATRIX_ACCESS_TOKEN=<secret>                 # from /login (docs/08)
MATRIX_DEVICE_NAME=<name>-voip
MATRIX_DEVICE_ID=<filled-on-login>
AUTHORIZED_USERS=@you:matrix.example.com     # comma-sep: who may CALL this persona
# Optional dedicated signaling/bridge account:
BRIDGE_USER_ID=@bridge:matrix.example.com
BRIDGE_ACCESS_TOKEN=<secret>

# ── End-to-end encryption (encrypted rooms only) ────────────────────────────
MATRIX_E2EE_ENABLED=true
MATRIX_E2EE_REQUIRED=false
MATRIX_AUTO_CROSS_SIGN=true
MATRIX_RESTORE_KEY_BACKUP_ON_START=true
CRYPTO_STORE_PATH=/home/USER/voip-<name>/crypto-store
MATRIX_CRYPTO_STORE_PASSWORD=<secret>
MATRIX_RECOVERY_KEY_FILE=/home/USER/voip-<name>/secrets/recovery-key.txt

# ── PipeWire virtual devices (created by the -stt/-tts loopback services) ────
PIPEWIRE_STT_SINK=input.<name>_stt_speaker
PIPEWIRE_STT_CAPTURE=<name>_stt_capture
PIPEWIRE_TTS_SINK=input.<name>_tts
PIPEWIRE_TTS_SOURCE=<name>_tts_mic

# ── Brain: LLM (vLLM, OpenAI-compatible) ────────────────────────────────────
VLLM_BASE_URL=http://INFER_HOST:8000/v1
VLLM_API_KEY=<secret-or-blank-on-trusted-lan>
VLLM_MODEL=qwen36-fast
VLLM_VOICE_FAST_MODEL=qwen36-fast            # low latency for live calls
VLLM_VOICE_DEEP_MODEL=qwen36-deep            # used when deeper reasoning is needed
VLLM_VOICE_THINKING_MODE=off                 # off = faster calls
VLLM_TEMPERATURE=0.7
VLLM_VOICE_MAX_TOKENS=512
VLLM_VOICE_CHAT_MAX_TOKENS=512
VLLM_VOICE_THINKING_MAX_TOKENS=1024
VLLM_SYSTEM_PROMPT=                          # blank = use the persona's SOUL via workspace

# ── Ears: STT / ASR ─────────────────────────────────────────────────────────
MAC_ASR_URL=http://INFER_HOST:8001/v1        # Qwen3-ASR (preferred)
MAC_ASR_MODEL=qwen3-asr
MAC_ASR_API_KEY=<secret-or-blank>
# Optional omni/alt ASR:
OMNI_ASR_ENABLED=false
OMNI_ASR_BASE_URL=http://INFER_HOST:8000/v1
OMNI_ASR_MODEL=your-omni-asr
# Local fallback (whisper.cpp):
WHISPER_ENABLED=false
#WHISPER_MODEL_PATH=/home/USER/whisper.cpp/models/ggml-base.bin
#WHISPER_SERVER_PORT=8178

# ── Voice: TTS (Qwen3-TTS) ──────────────────────────────────────────────────
VOXTRAL_ENABLED=true
VOXTRAL_BASE_URL=http://INFER_HOST:8002/v1
VOXTRAL_MODEL=qwen3-tts-clone
VOXTRAL_VOICE=<name>
VOXTRAL_API_KEY=<secret-or-blank>
VOXTRAL_TTS_MODE=voice_design                # voice_design | voice_clone  (docs/06)
VOXTRAL_VOICE_DESCRIPTION=A warm, clear, mid-pitched voice with measured cadence.
VOXTRAL_VOICE_STYLE_FIELD=instructions
VOXTRAL_LANGUAGE=English
VOXTRAL_STREAMING=true
VOXTRAL_TTS_TIMEOUT_MS=120000
VOXTRAL_TTS_MAX_NEW_TOKENS=4096
VOXTRAL_TTS_MODE_NOTE=set voice_clone + drop reference audio where the TTS server reads voices

# ── Call behavior ───────────────────────────────────────────────────────────
MAX_CONCURRENT_CALLS=1
CALL_TIMEOUT_MS=1800000                       # 30 min hard cap
VOICE_TTS_RESPONSE_MODE=full
VOICE_HISTORY_MAX_MESSAGES=24                 # rolling conversation memory
VOICE_HISTORY_KEEP_MESSAGES=12
VOICE_CALLER_NAME=Alex                        # how the persona addresses the caller
# Optional: let the persona read a few workspace files as "voice memory"
VOICE_MEMORY_ENABLED=false
VOICE_MEMORY_PATHS=/home/USER/.openclaw/workspace-<name>/SOUL.md,/home/USER/.openclaw/workspace-<name>/IDENTITY.md

# ── Per-agent HTTP API (localhost only) ─────────────────────────────────────
API_PORT=8210                                 # UNIQUE per persona — keep a registry
API_TOKEN=<secret>                            # bearer for /call /hangup /status
LOG_LEVEL=info

# ── Optional: tools the persona can use during a call ───────────────────────
BRAVE_SEARCH_API_KEY=<secret-or-blank>        # for in-call web_search, if enabled
